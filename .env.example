# Turso (libSQL) credentials for the shared leaderboard API (api/leaderboard.ts).
#
# On Vercel these are injected automatically by the Turso marketplace
# integration, prefixed (e.g. CRSTL_). For local `vercel dev`, copy this file
# to `.env.local` and fill in the values from your Turso dashboard.
#
# Env precedence (highest first):
#   CRSTL_DEV_TURSO_*  -> dedicated dev database; set ONLY on the Vercel Preview
#                         environment so the `dev` branch / previews keep their
#                         leaderboard separate from production.
#   CRSTL_TURSO_*      -> production database (Turso marketplace integration).
#   TURSO_*            -> fallback for `vercel dev` / manual setups.

# Production (and the marketplace integration sets these automatically):
CRSTL_TURSO_DATABASE_URL=
CRSTL_TURSO_AUTH_TOKEN=

# Dev/preview-only database — scope these to the Preview environment in Vercel:
# CRSTL_DEV_TURSO_DATABASE_URL=
# CRSTL_DEV_TURSO_AUTH_TOKEN=

# Fallback / non-Vercel setups:
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
